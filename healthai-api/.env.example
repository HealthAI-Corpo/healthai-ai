# --- Serveur ---
SERVICE_PORT=8000
LOG_LEVEL=info

# --- Micro-services IA (réseau interne docker-compose) ---
VISION_SERVICE_URL=http://healthai-vision:8001
WORKOUT_SERVICE_URL=http://healthai-workout:8002

# --- Base de données applicative (lookup id_utilisateur depuis email JWT) ---
# Le driver async doit être explicite dans l'URL (ex. asyncpg pour Postgres).
# Pour utiliser un autre moteur, change l'URL — aucune transformation côté code.
DATABASE_URL=postgresql+asyncpg://healthai:healthai@postgres:5432/healthai_db

# --- Auth ---
# "dev_stub" : pas de validation Zitadel, toutes les requêtes -> DEV_STUB_USER_ID.
# "jwks"     : validation complète du Bearer token Zitadel + lookup id en DB.
AUTH_MODE=dev_stub
DEV_STUB_USER_ID=1
DEV_STUB_USER_EMAIL=dev@healthai.local

# --- Zitadel (requis si AUTH_MODE=jwks) ---
# Issuer Zitadel (en prod : http://zitadel:8080 sur le réseau infra)
ZITADEL_ISSUER=http://zitadel:8080
# Audience attendue (project id / client id Zitadel — vide = pas de check d'audience)
JWT_AUDIENCE=
# Rôle projet requis (vide = juste authentification, pas de check de rôle)
ZITADEL_REQUIRED_ROLE=ai-user

# --- Cache mapping email -> id_utilisateur ---
USER_ID_CACHE_TTL_SECONDS=300

# --- CORS (CSV des origines autorisées) ---
CORS_ORIGINS=http://localhost:3000
