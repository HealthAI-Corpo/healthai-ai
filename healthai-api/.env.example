# --- Serveur ---
SERVICE_PORT=8000
LOG_LEVEL=info

# --- Micro-services IA (réseau interne docker-compose) ---
VISION_SERVICE_URL=http://healthai-vision:8001
WORKOUT_SERVICE_URL=http://healthai-workout:8002

# --- Base de données applicative (résout id_utilisateur depuis l'email) ---
# Le driver async doit être explicite dans l'URL (ex. asyncpg pour Postgres).
# Pour utiliser un autre moteur, change l'URL — aucune transformation côté code.
DATABASE_URL=postgresql+asyncpg://healthai:healthai@postgres:5432/healthai_db

# --- Auth ---
# "dev_stub" : pas de validation Zitadel, toutes les requêtes -> DEV_STUB_USER_ID.
# "jwks"     : valide l'ACCESS TOKEN Zitadel (JWKS) + récupère l'email via
#              l'endpoint userinfo, puis lookup id en DB. C'est le mode cible.
# "id_token" : valide un ID TOKEN Zitadel et lit l'email dans le claim `email`
#              (transition/dépannage — peut être retiré ensuite).
AUTH_MODE=dev_stub
DEV_STUB_USER_ID=1
DEV_STUB_USER_EMAIL=dev@healthai.local

# --- Zitadel (requis si AUTH_MODE=jwks ou id_token) ---
# ⚠️ Doit valoir l'URL EXTERNE de Zitadel = exactement le claim `iss` du token
# (pas le nom interne docker), sinon la validation échoue ("Invalid issuer").
# Cette URL sert AUSSI à appeler JWKS + userinfo : si elle pointe sur localhost,
# le container doit pouvoir l'atteindre (cf. extra_hosts dans healthai-infra).
ZITADEL_ISSUER=http://localhost:8080
# Audience attendue (client id Zitadel — vide = pas de check d'audience)
JWT_AUDIENCE=
# Rôle projet requis (vide = juste authentification, pas de check de rôle)
ZITADEL_REQUIRED_ROLE=

# --- Cache mapping sub -> id_utilisateur (évite userinfo + DB à chaque requête) ---
USER_ID_CACHE_TTL_SECONDS=300

# --- CORS (CSV des origines autorisées) ---
CORS_ORIGINS=http://localhost:3000
