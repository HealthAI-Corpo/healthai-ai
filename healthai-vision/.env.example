# --- Base de données PostgreSQL (lecture table aliment + analyse_repas) ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/healthai_db

# --- Base de données MongoDB (persistance aliment) ---
MONGODB_URL=mongodb://mongodb_user:mongodb_password@localhost:27017/mongodb_db

# --- Authentification inter-services (forward-auth NestJS) ---
INTERNAL_API_URL=http://healthai-api:3000
INTERNAL_API_KEY=change-me-min-32-chars-xxxxxxxxxxxxxxxx

# --- Modèle HuggingFace ---
# Nom du modèle sur HuggingFace Hub
HF_MODEL_NAME=BinhQuocNguyen/food-recognition-model
# Dossier local de cache pour éviter le re-téléchargement
HF_CACHE_DIR=/app/.hf_cache

# --- Rate limiting ---
# Requêtes max par minute par IP
RATE_LIMIT_PER_MINUTE=10

# --- Service ---
SERVICE_PORT=8001
LOG_LEVEL=INFO
