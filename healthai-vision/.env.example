# --- Service ---
SERVICE_PORT=8001
LOG_LEVEL=INFO

# --- PostgreSQL (table aliment + analyse_repas) ---
DATABASE_URL=postgresql+asyncpg://healthai:healthai@postgres:5432/healthai_db

# --- MongoDB (historique consumptions + suggestions) ---
MONGODB_URL=mongodb://mongo:27017

# --- LLM Ollama (partagé avec le docker-compose) ---
OLLAMA_BASE_URL=http://healthai-ollama:11434
OLLAMA_MODEL=qwen2.5:0.5b
# Maintient le modèle en mémoire pour éviter les rechargements (180 s sur CPU)
OLLAMA_KEEP_ALIVE=24h

# --- Modèle HuggingFace YOLO ---
HF_MODEL_NAME=yolov8n.pt
HF_CACHE_DIR=/app/.hf_cache
