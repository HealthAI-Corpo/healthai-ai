# --- Racine du repo ---
# Ce .env est lu par docker compose pour les variables top-level (ports, urls partagees).
# Chaque service a son propre .env (healthai-api/.env, healthai-vision/.env, etc.)
# qui copie de son .env.example.

# --- DBs et URLs ---
# DATABASE_URL : utilise principalement par docker-compose.dev.yml pour overrider la conf
# par defaut de vision/workout (qui pointent par defaut vers postgres:5432 embarque).
# Pour le mode .dev (branche sur healthai-infra), pointer vers host.docker.internal.
DATABASE_URL=postgresql+asyncpg://healthai:healthai@host.docker.internal:5432/healthai_db
MONGODB_URL=mongodb://mongo:27017

# --- Ports d'exposition (mode dev uniquement) ---
HEALTHAI_API_PORT=8000
HEALTHAI_VISION_PORT=8001
HEALTHAI_WORKOUT_PORT=8002
MONGO_PORT=27017

# --- LLM Ollama (modele partage) ---
# Reference par les services vision et workout via le docker-compose.
OLLAMA_MODEL=llama3.2:3b
# Modele utilise par vision (plus petit pour la nutrition)
HF_MODEL_NAME=yolov8n.pt
