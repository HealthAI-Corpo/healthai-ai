# --- Service ---
SERVICE_PORT=8002
LOG_LEVEL=INFO

# --- PostgreSQL (lecture profil + log_seance, écriture sur sauvegarder=true) ---
DATABASE_URL=postgresql+asyncpg://healthai:healthai@postgres:5432/healthai_db

# --- MongoDB (jobs IA `ai_jobs` + traces `predictions`) ---
MONGODB_URL=mongodb://mongo:27017
MONGODB_DB_NAME=healthai_workout

# --- LLM Ollama (partagé avec le docker-compose) ---
OLLAMA_BASE_URL=http://healthai-ollama:11434
OLLAMA_MODEL=llama3.2:3b

# --- Modèle ML calories (chargé au démarrage par le lifespan) ---
MODEL_PATH=/app/models/CaloriesIA_1_0_0/random_forest/model.pkl