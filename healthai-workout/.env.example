# --- MongoDB (recommandations NoSQL) ---
MONGODB_URL=mongodb://user:password@localhost:27017
MONGODB_DB_NAME=healthai_workout

# --- Base de données PostgreSQL (lecture table exercice) ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/healthai_db

# --- Authentification inter-services ---
INTERNAL_API_URL=http://healthai-api:3000
INTERNAL_API_KEY=change-me-min-32-chars-xxxxxxxxxxxxxxxx

# --- Modèle ML ---
